:root {
  color-scheme: light;
  --bg: #eef5f2;
  --panel: rgba(255, 255, 255, 0.96);
  --panel-solid: #ffffff;
  --panel-2: #eef4fb;
  --panel-3: #f8fafc;
  --glass-dark: rgba(15, 23, 42, 0.76);
  --glass-darker: rgba(15, 23, 42, 0.88);
  --text: #111827;
  --muted: #526070;
  --line: #cbd5e1;
  --accent: #22c55e;
  --accent-dark: #16a34a;
  --warn: #dc2626;
  --input: #ffffff;
  --button: #e2e8f0;
  --map-bg: #dbeafe;
  --shadow: 0 18px 48px rgba(15, 23, 42, 0.18);
  --radius: 18px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}

[data-theme="dark"] {
  color-scheme: dark;
  --bg: #08111f;
  --panel: rgba(17, 24, 39, 0.96);
  --panel-solid: #111827;
  --panel-2: #172033;
  --panel-3: #0b1220;
  --glass-dark: rgba(3, 7, 18, 0.78);
  --glass-darker: rgba(3, 7, 18, 0.92);
  --text: #f8fafc;
  --muted: #a9b4c7;
  --line: #2b3547;
  --accent: #22c55e;
  --accent-dark: #16a34a;
  --warn: #f87171;
  --input: #0b1220;
  --button: #263349;
  --map-bg: #07111d;
  --shadow: 0 20px 54px rgba(0, 0, 0, 0.34);
}

* { box-sizing: border-box; }
html, body { min-height: 100%; }
html { background: var(--bg); }
body {
  margin: 0;
  overflow: hidden;
  color: var(--text);
  font-family: "Cascadia Mono", "Segoe UI Mono", "Roboto Mono", Consolas, ui-monospace, monospace;
  background: var(--bg);
}

button,
input,
select,
textarea { font: inherit; }
button { cursor: pointer; }
button:disabled { cursor: progress; opacity: 0.62; }

.app-shell {
  position: relative;
  width: 100vw;
  height: 100dvh;
  overflow: hidden;
  background: var(--map-bg);
}

.dashboard,
.map-panel,
.flight-map {
  position: absolute;
  inset: 0;
}
.dashboard { display: block; margin: 0; }
.map-panel {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}
.flight-map {
  width: 100%;
  height: 100%;
  min-height: 100%;
  border: 0;
  border-radius: 0;
  overflow: hidden;
  background: var(--map-bg);
}

.leaflet-container { font: inherit; }
.leaflet-top.leaflet-left { top: 86px; }
.leaflet-control-attribution { font-size: 0.68rem; }
.leaflet-interactive { stroke-linecap: round; stroke-linejoin: round; }
.leaflet-popup-content-wrapper,
.leaflet-popup-tip {
  color: var(--text);
  background: var(--panel-solid);
}

.topbar {
  position: fixed;
  top: calc(12px + env(safe-area-inset-top, 0px));
  left: 50%;
  z-index: 7200;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  width: min(760px, calc(100vw - 24px));
  min-height: 62px;
  padding: 9px 14px;
  border: 1px solid rgba(255, 255, 255, 0.28);
  border-radius: 20px;
  color: #ecfdf5;
  background: linear-gradient(135deg, var(--glass-darker), rgba(22, 101, 52, 0.72));
  box-shadow: var(--shadow);
  backdrop-filter: blur(14px);
  transform: translateX(-50%);
}
.brand-block { min-width: 0; }
.eyebrow {
  margin: 0 0 2px;
  color: #bbf7d0;
  font-size: 0.66rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
h1, h2, p { margin-top: 0; }
h1 {
  margin-bottom: 0;
  font-size: clamp(1.08rem, 3.4vw, 1.55rem);
  line-height: 1.05;
}
h2 { margin-bottom: 0; font-size: 1.05rem; }
.version-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 5px;
}
.version-badge,
.status-chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  margin: 0;
  padding: 3px 8px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 999px;
  color: #ecfdf5;
  background: rgba(15, 23, 42, 0.32);
  font-size: 0.72rem;
  font-weight: 900;
}
.status-chip { background: rgba(34, 197, 94, 0.26); }
.status-chip[data-mode="busy"] { background: rgba(251, 191, 36, 0.34); }
.status-chip[data-mode="error"] { background: rgba(248, 113, 113, 0.36); }

.map-tools-card {
  position: fixed;
  top: calc(88px + env(safe-area-inset-top, 0px));
  right: 12px;
  z-index: 6500;
  width: min(320px, calc(100vw - 24px));
  margin: 0;
  padding: 10px;
  border: 1px solid rgba(15, 23, 42, 0.12);
  border-radius: 16px;
  background: var(--panel);
  box-shadow: var(--shadow);
  backdrop-filter: blur(14px);
}
.map-tools-card .panel-subtitle { display: none; }

.map-floating-controls {
  position: fixed;
  right: calc(14px + env(safe-area-inset-right, 0px));
  bottom: calc(154px + var(--safe-bottom));
  z-index: 7305;
  display: grid;
  gap: 8px;
  pointer-events: auto;
}
.map-location-button {
  display: grid;
  place-items: center;
  width: 46px;
  height: 46px;
  border: 1px solid rgba(15, 23, 42, 0.16);
  border-radius: 16px;
  color: #0f172a;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: var(--shadow);
  font-size: 1.35rem;
  font-weight: 950;
  line-height: 1;
  backdrop-filter: blur(14px);
  touch-action: manipulation;
}
.map-location-button:hover,
.map-location-button:focus-visible {
  background: #ffffff;
  transform: translateY(-1px);
}
.user-location-div-icon {
  position: relative;
  display: grid;
  place-items: center;
  background: transparent;
}
.user-location-dot {
  position: absolute;
  width: 15px;
  height: 15px;
  border: 3px solid #ffffff;
  border-radius: 999px;
  background: #2563eb;
  box-shadow: 0 4px 18px rgba(37, 99, 235, 0.44);
}
.user-location-pulse {
  position: absolute;
  width: 30px;
  height: 30px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.2);
}

.map-status-card {
  position: fixed;
  left: 50%;
  bottom: calc(92px + var(--safe-bottom));
  z-index: 6200;
  width: min(680px, calc(100vw - 24px));
  margin: 0;
  padding: 9px 12px;
  border: 1px solid rgba(15, 23, 42, 0.12);
  border-radius: 999px;
  color: #052e16;
  background: rgba(220, 252, 231, 0.94);
  box-shadow: var(--shadow);
  font-size: 0.82rem;
  font-weight: 850;
  text-align: center;
  transform: translateX(-50%);
  backdrop-filter: blur(14px);
}

.control-column {
  position: fixed;
  left: 50%;
  bottom: calc(96px + var(--safe-bottom));
  z-index: 7000;
  display: block;
  width: min(760px, calc(100vw - 18px));
  max-height: min(72dvh, 720px);
  overflow: auto;
  padding: 10px;
  border: 1px solid rgba(15, 23, 42, 0.14);
  border-radius: 24px;
  background: var(--panel);
  box-shadow: var(--shadow);
  backdrop-filter: blur(18px);
  opacity: 0;
  pointer-events: none;
  transform: translate(-50%, 18px) scale(0.98);
  transition: opacity 160ms ease, transform 160ms ease;
}
.control-column.is-open {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, 0) scale(1);
}
.drawer-header {
  position: sticky;
  top: -10px;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin: -10px -10px 10px;
  padding: 11px 12px;
  border-bottom: 1px solid var(--line);
  border-radius: 24px 24px 0 0;
  background: var(--panel-solid);
}
.drawer-header strong { font-size: 0.98rem; }
.drawer-close { display: none !important; }
.drawer-drag-handle,
.aircraft-sheet-drag-handle {
  display: none;
  width: 54px;
  height: 5px;
  margin: 0 auto 8px;
  border-radius: 999px;
  background: rgba(100, 116, 139, 0.45);
}
.drawer-header { flex-direction: column; align-items: center; justify-content: center; }
.drawer-header strong { width: 100%; text-align: left; }
.drawer-panel { display: none !important; }
.drawer-panel.is-active { display: block !important; }
.status-panel.drawer-panel.is-active { display: flex !important; }

.bottom-nav {
  position: fixed;
  left: 50%;
  bottom: calc(12px + var(--safe-bottom));
  z-index: 7300;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6px;
  width: min(720px, calc(100vw - 18px));
  padding: 8px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 28px;
  background: var(--glass-darker);
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.34);
  backdrop-filter: blur(18px);
  transform: translateX(-50%);
}
.bottom-nav button {
  display: grid;
  place-items: center;
  gap: 2px;
  min-width: 0;
  min-height: 58px;
  border: 0;
  border-radius: 20px;
  color: rgba(255, 255, 255, 0.9);
  background: transparent;
  font-size: 0.82rem;
  font-weight: 850;
}
.bottom-nav button.is-active,
.bottom-nav button:focus-visible {
  color: #052e16;
  background: #bbf7d0;
  outline: none;
}
.nav-icon {
  display: block;
  font-size: 1.48rem;
  line-height: 1;
}

.bottom-more-menu {
  position: fixed;
  left: 50%;
  bottom: calc(92px + var(--safe-bottom));
  z-index: 7350;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  width: min(430px, calc(100vw - 18px));
  padding: 10px;
  border: 1px solid rgba(255, 255, 255, 0.28);
  border-radius: 24px;
  background: rgba(15, 23, 42, 0.94);
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.36);
  backdrop-filter: blur(18px);
  transform: translateX(-50%);
}
.bottom-more-menu[hidden] { display: none !important; }
.bottom-more-menu button {
  display: grid;
  grid-template-columns: 32px 1fr;
  align-items: center;
  gap: 8px;
  min-height: 46px;
  padding: 8px 10px;
  border: 0;
  border-radius: 16px;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.08);
  font-size: 0.9rem;
  font-weight: 850;
  text-align: left;
}
.bottom-more-menu button:focus-visible,
.bottom-more-menu button:hover {
  color: #052e16;
  background: #bbf7d0;
  outline: none;
}
.bottom-more-menu .nav-icon {
  font-size: 1.2rem;
  text-align: center;
}

.panel,
.saved-section,
.status-panel {
  padding: 14px;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 18px;
  background: transparent;
  box-shadow: none;
}
.panel-head,
.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}
.panel-subtitle {
  margin: 3px 0 0;
  color: var(--muted);
  font-size: 0.82rem;
  font-weight: 650;
}

form,
.import-panel { display: grid; gap: 12px; }
label {
  display: grid;
  gap: 7px;
  color: var(--muted);
  font-size: 0.86rem;
  font-weight: 750;
}
input,
select,
textarea {
  width: 100%;
  min-height: 44px;
  border: 1px solid var(--line);
  border-radius: 12px;
  outline: none;
  color: var(--text);
  background: var(--input);
  padding: 10px 12px;
}
textarea { resize: vertical; min-height: 86px; }
input:focus,
select:focus,
textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.18);
}
.grid-two,
.grid-three { display: grid; gap: 12px; }
.grid-two { grid-template-columns: 1fr 1fr; }
.grid-three { grid-template-columns: 1fr 1fr 0.8fr; }
.api-row {
  display: grid;
  grid-template-columns: 1fr 1fr auto;
  gap: 12px;
  align-items: end;
}
.api-row .secondary-button { min-width: 132px; }
.api-details { margin: 0 0 12px; }

details {
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--input);
  padding: 12px;
}
summary { color: var(--muted); font-weight: 850; cursor: pointer; }
.details-grid { margin-top: 12px; }
.radar-main-actions { margin-bottom: 12px; }
.radar-main-actions .primary-button { flex-basis: 190px; }
.radar-position-grid { margin-bottom: 4px; }

.filter-details {
  margin: 10px 0 10px;
  padding: 10px;
  background: var(--panel-3);
}
.filter-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.9fr 0.9fr;
  gap: 10px;
  margin-top: 10px;
}
.checkbox-filter-row {
  display: flex;
  align-items: center;
  gap: 8px;
  min-height: 44px;
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--input);
}
.checkbox-filter-row input {
  width: 18px;
  min-height: 18px;
  height: 18px;
  margin: 0;
}
.filter-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 8px;
}
.advanced-api-details { margin-top: 12px; }
.advanced-api-details[open] { background: var(--panel-2); }
.advanced-api-grid { margin-top: 12px; }
.api-base-row { margin-top: 12px; }
.actions,
.small-actions,
.flight-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}
.actions { flex-wrap: wrap; }
.primary-button,
.secondary-button,
.ghost-button,
.icon-button {
  min-height: 42px;
  border: 0;
  border-radius: 12px;
  font-weight: 850;
}
.primary-button {
  flex: 1 1 160px;
  color: #052e16;
  background: var(--accent);
}
.primary-button:active { background: var(--accent-dark); }
.secondary-button {
  flex: 1 1 130px;
  color: var(--text);
  background: var(--button);
}
.ghost-button {
  color: var(--muted);
  background: transparent;
  padding: 0 9px;
}
.ghost-button.danger,
.icon-button.danger { color: var(--warn); }
.icon-button {
  display: inline-grid;
  place-items: center;
  width: auto;
  min-width: 64px;
  padding: 0 10px;
  color: var(--text);
  background: var(--button);
}
.full-width { width: 100%; }

.empty-state {
  display: grid;
  gap: 5px;
  padding: 16px;
  border: 1px dashed var(--line);
  border-radius: 14px;
  color: var(--muted);
  background: var(--panel-3);
}
.empty-state strong { color: var(--text); }
.flight-list,
.aircraft-list {
  display: grid;
  gap: 10px;
  margin: 0;
  padding: 0;
  list-style: none;
}
.aircraft-list,
.flight-list {
  max-height: 38dvh;
  overflow: auto;
  padding-right: 2px;
}
.flight-item,
.aircraft-item {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 10px;
  min-height: 54px;
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--panel-2);
}
.aircraft-item { grid-template-columns: minmax(0, 1fr) auto auto auto; min-height: 68px; }
.aircraft-pick {
  display: grid;
  grid-template-columns: 92px 1fr;
  align-items: center;
  gap: 12px;
  min-height: 48px;
  border: 0;
  color: inherit;
  text-align: left;
  background: transparent;
}
.aircraft-text-block,
.flight-main {
  display: grid;
  gap: 4px;
  min-width: 0;
}
.aircraft-title,
.flight-name { overflow-wrap: anywhere; font-weight: 900; }
.aircraft-meta,
.aircraft-extra,
.flight-meta,
.status-line { color: var(--muted); font-size: 0.84rem; }
.status-line { margin: 12px 0 10px; }
.flight-card-main {
  display: grid;
  grid-template-columns: 34px 1fr;
  align-items: center;
  gap: 8px;
  min-width: 0;
}
.flight-thumb {
  width: 34px;
  height: 34px;
  object-fit: cover;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--panel-solid);
  box-shadow: none;
}
.aircraft-thumb {
  width: 76px;
  height: 48px;
  object-fit: cover;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: var(--panel-solid);
  box-shadow: 0 5px 12px rgba(15, 23, 42, 0.12);
}

.status-panel {
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}
.status-main { display: grid; gap: 3px; min-width: 0; }
.status-label {
  color: var(--muted);
  font-size: 0.74rem;
  font-weight: 900;
  text-transform: uppercase;
}
#lastStatusText { overflow-wrap: anywhere; }
#lastStatusTime { color: var(--muted); font-size: 0.82rem; }
.status-copy-button { flex: 0 0 auto; min-width: 130px; }
.settings-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; align-items: end; }
.settings-note { margin: 12px 0 0; color: var(--muted); font-size: 0.84rem; }
.update-button,
.compact-button { white-space: nowrap; }
.update-button {
  min-height: 44px;
  padding: 0 14px;
  color: #052e16;
  background: #bbf7d0;
}
.compact-button { min-width: 104px; padding: 0 12px; }

.map-popup { display: grid; gap: 3px; min-width: 168px; max-width: 220px; font-size: 0.86rem; }
.map-popup-title { color: var(--text); }
.map-popup-meta { color: var(--muted); }
.map-popup-route,
.aircraft-route { color: var(--accent-dark); font-size: 0.82rem; font-weight: 900; }
.map-popup-note { color: var(--muted); font-size: 0.76rem; }
.map-popup-photo {
  width: 168px;
  height: 88px;
  object-fit: cover;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--panel-2);
}

.toast {
  position: fixed;
  left: 50%;
  top: calc(84px + env(safe-area-inset-top, 0px));
  z-index: 10001;
  max-width: min(88vw, 520px);
  transform: translate(-50%, -14px);
  padding: 9px 13px;
  border-radius: 18px;
  color: #052e16;
  background: rgba(187, 247, 208, 0.96);
  box-shadow: 0 12px 32px rgba(15, 23, 42, 0.24);
  font-size: 0.86rem;
  font-weight: 850;
  line-height: 1.28;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 160ms ease, transform 160ms ease, visibility 160ms ease;
}
.toast.show {
  transform: translate(-50%, 0);
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.busy-overlay {
  position: fixed;
  left: 50%;
  top: calc(88px + env(safe-area-inset-top, 0px));
  z-index: 10000;
  transform: translateX(-50%);
  pointer-events: none;
}
.busy-card {
  display: flex;
  align-items: center;
  gap: 10px;
  max-width: min(92vw, 620px);
  padding: 12px 16px;
  border: 1px solid rgba(15, 23, 42, 0.14);
  border-radius: 999px;
  color: #052e16;
  background: #dcfce7;
  box-shadow: 0 16px 42px rgba(15, 23, 42, 0.22);
  font-weight: 900;
}
.busy-spinner {
  width: 18px;
  height: 18px;
  border: 3px solid rgba(5, 46, 22, 0.22);
  border-top-color: #16a34a;
  border-radius: 50%;
  animation: busy-spin 0.75s linear infinite;
}
@keyframes busy-spin { to { transform: rotate(360deg); } }

.aircraft-div-icon,
.route-endpoint-div-icon { background: transparent !important; border: 0 !important; }
.plane-marker-wrap {
  display: grid;
  place-items: center;
  transform: translateY(-8px);
  pointer-events: auto;
}
.plane-marker {
  display: grid;
  place-items: center;
  width: 32px;
  height: 32px;
  border: 0;
  border-radius: 0;
  color: #0f766e;
  background: transparent;
  box-shadow: none;
  transform: rotate(var(--heading));
  filter: drop-shadow(0 2px 1px rgba(255,255,255,.9)) drop-shadow(0 5px 6px rgba(15,23,42,.36));
}
.plane-marker.special,
.aircraft-kind-special .plane-marker { color: #dc2626; }
.aircraft-kind-heavy .plane-marker { width: 36px; height: 36px; color: #1d4ed8; }
.aircraft-kind-prop .plane-marker { color: #0f766e; }
.aircraft-kind-helicopter .plane-marker { color: #9333ea; }
.aircraft-kind-glider .plane-marker { color: #0369a1; }
.plane-marker svg {
  width: 28px;
  height: 28px;
  fill: currentColor;
  stroke: rgba(255,255,255,.95);
  stroke-width: 2.2px;
  paint-order: stroke fill;
  filter: none;
}
.plane-label {
  margin-top: -4px;
  padding: 2px 5px;
  border: 1px solid rgba(15, 23, 42, 0.2);
  border-radius: 999px;
  color: #0f172a;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 5px 12px rgba(15, 23, 42, 0.2);
  font-size: 0.58rem;
  font-weight: 900;
  white-space: nowrap;
}
.route-endpoint {
  display: grid;
  place-items: center;
  height: 28px;
  min-width: 58px;
  padding: 0 10px;
  border: 2px solid rgba(255,255,255,.95);
  border-radius: 999px;
  color: #052e16;
  background: #bbf7d0;
  box-shadow: 0 8px 16px rgba(15, 23, 42, 0.24);
  font-size: 0.68rem;
  font-weight: 950;
}
.route-endpoint.end { color: #450a0a; background: #fecaca; }

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
}


.leaflet-popup-content {
  max-width: min(260px, calc(100vw - 64px));
  max-height: 56dvh;
  overflow: auto;
}

@media (max-width: 760px) {
  .topbar {
    top: calc(8px + env(safe-area-inset-top, 0px));
    width: calc(100vw - 16px);
    min-height: 58px;
    padding: 8px 12px;
    border-radius: 18px;
  }
  .eyebrow { display: none; }
  .version-row { margin-top: 4px; }
  .version-badge { display: none; }
  .map-tools-card {
    top: calc(74px + env(safe-area-inset-top, 0px));
    right: 8px;
    width: auto;
    max-width: calc(100vw - 16px);
    padding: 8px;
  }
  .map-tools-card h2 { display: none; }
  .map-status-card {
    bottom: calc(88px + var(--safe-bottom));
    width: calc(100vw - 18px);
    font-size: 0.76rem;
  }
  .control-column {
    bottom: calc(88px + var(--safe-bottom));
    width: calc(100vw - 12px);
    max-height: min(72dvh, 640px);
    border-radius: 22px;
  }
  .drawer-header { border-radius: 22px 22px 0 0; }
  .bottom-nav {
    bottom: calc(8px + var(--safe-bottom));
    grid-template-columns: repeat(5, minmax(0, 1fr));
    width: calc(100vw - 10px);
    padding: 6px;
    border-radius: 24px;
  }
  .bottom-nav button {
    min-height: 58px;
    border-radius: 18px;
    font-size: 0.72rem;
  }
  .bottom-more-menu {
    bottom: calc(86px + var(--safe-bottom));
    width: calc(100vw - 18px);
  }
  .nav-icon { font-size: 1.28rem; }
  .grid-two,
  .grid-three,
  .api-row,
  .filter-grid,
  .flight-item,
  .aircraft-item,
  .status-panel,
  .settings-grid { grid-template-columns: 1fr; }
  .status-panel.drawer-panel.is-active { display: grid !important; align-items: stretch; }
  .theme-control,
  .update-button,
  .compact-button,
  .status-copy-button { min-width: 0; width: 100%; }
  .flight-actions { justify-content: stretch; flex-wrap: wrap; }
  .flight-actions .icon-button { flex: 1 1 calc(50% - 8px); }
  .aircraft-pick { grid-template-columns: 70px 1fr; }
  .aircraft-item { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .aircraft-item .aircraft-pick { grid-column: 1 / -1; }
  .aircraft-item .secondary-button { width: 100%; min-width: 0; }
  .flight-card-main { grid-template-columns: 30px 1fr; }
  .flight-thumb { width: 30px; height: 30px; }
  .aircraft-thumb { width: 70px; height: 44px; }
  .flight-item { grid-template-columns: 1fr; gap: 6px; padding: 7px 8px; }
  .flight-item .flight-actions { grid-template-columns: repeat(3, 1fr); width: 100%; }
  .flight-item .icon-button { min-width: 0; min-height: 30px; font-size: 0.68rem; padding: 0 4px; }

  .leaflet-popup-content-wrapper { border-radius: 12px; }
  .leaflet-popup-content {
    margin: 8px 9px;
    max-width: min(218px, calc(100vw - 58px));
    max-height: 42dvh;
    overflow: auto;
  }
  .map-popup {
    min-width: 0;
    max-width: 210px;
    gap: 3px;
    font-size: 0.78rem;
  }
  .map-popup-photo { width: 118px; height: 66px; }
  .map-popup-note { font-size: 0.66rem; }
  .map-popup-meta,
  .map-popup-route { font-size: 0.74rem; }
  .plane-marker { width: 28px; height: 28px; }
  .aircraft-kind-heavy .plane-marker { width: 32px; height: 32px; }
  .plane-marker svg { width: 24px; height: 24px; }
  .plane-label { font-size: 0.52rem; padding: 1px 4px; }

  .aircraft-list,
  .flight-list { max-height: 34dvh; }
  .leaflet-top.leaflet-left { top: 132px; }
  .toast {
    top: calc(70px + env(safe-area-inset-top, 0px));
    max-width: calc(100vw - 26px);
    padding: 8px 11px;
    border-radius: 14px;
    font-size: 0.78rem;
  }
  .advanced-api-details { margin-top: 10px; }
}


.flight-item .flight-actions {
  display: grid;
  grid-template-columns: repeat(5, auto);
  gap: 4px;
}
.flight-item .icon-button {
  min-width: 44px;
  min-height: 32px;
  padding: 0 7px;
  border-radius: 9px;
  font-size: 0.72rem;
}
.flight-item .delete-flight { color: var(--warn); }
.popup-save-button {
  width: 100%;
  min-height: 34px;
  margin-top: 4px;
  font-size: 0.82rem;
}

@media (max-width: 760px) {
  .flight-item .flight-actions {
    grid-template-columns: repeat(7, 1fr);
    width: 100%;
  }
  .flight-item .icon-button {
    min-width: 0;
    min-height: 30px;
    font-size: 0.68rem;
    padding: 0 4px;
  }
}

.saved-search-row {
  margin: 0 0 8px;
}
.saved-search-row input {
  min-height: 36px;
  padding: 7px 10px;
  border-radius: 10px;
  font-size: 0.82rem;
}

/* v2.2: panel bez krzyżyków, kliknięcie poza panelem zamyka, kompakt zapisanych */
.flight-list {
  gap: 5px;
  max-height: 50dvh;
}
.flight-item {
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 6px;
  min-height: 40px;
  padding: 5px 7px;
  border-radius: 10px;
}
.flight-card-main {
  grid-template-columns: 26px minmax(0, 1fr);
  gap: 6px;
}
.flight-thumb {
  width: 26px;
  height: 26px;
  border-radius: 8px;
}
.flight-name {
  font-size: 0.78rem;
  line-height: 1.05;
}
.flight-meta {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 0.66rem;
}
.flight-item .flight-actions {
  display: flex;
  gap: 3px;
  align-items: center;
  justify-content: flex-end;
}
.flight-item .icon-button {
  min-width: 34px;
  min-height: 26px;
  padding: 0 5px;
  border-radius: 8px;
  font-size: 0.62rem;
}

.aircraft-sheet {
  position: fixed;
  left: 50%;
  bottom: calc(92px + var(--safe-bottom));
  z-index: 7250;
  display: grid;
  gap: 8px;
  width: min(640px, calc(100vw - 18px));
  max-height: min(58dvh, 520px);
  overflow: auto;
  padding: 10px;
  border: 1px solid rgba(15, 23, 42, 0.16);
  border-radius: 20px;
  color: var(--text);
  background: var(--panel-solid);
  box-shadow: 0 22px 60px rgba(15, 23, 42, 0.28);
  transform: translate(-50%, 14px);
  opacity: 0;
  transition: opacity 160ms ease, transform 160ms ease;
}
.aircraft-sheet.is-open {
  opacity: 1;
  transform: translate(-50%, 0);
}
.aircraft-sheet-head,
.aircraft-sheet-hero,
.aircraft-sheet-actions {
  display: flex;
  align-items: center;
  gap: 10px;
}
.aircraft-sheet-head { justify-content: space-between; }
.aircraft-title-group {
  display: grid;
  min-width: 0;
}
.aircraft-title-group strong {
  overflow: hidden;
  color: #facc15;
  font-size: 1.05rem;
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.aircraft-title-group span {
  color: var(--muted);
  font-size: 0.76rem;
  font-weight: 850;
}
.aircraft-sheet-close {
  display: none !important;
  width: 34px;
  height: 34px;
  border: 0;
  border-radius: 10px;
  color: var(--muted);
  background: transparent;
  font-size: 1.5rem;
  line-height: 1;
}
.aircraft-sheet-hero {
  align-items: stretch;
}
.aircraft-sheet-photo-wrap {
  flex: 0 0 132px;
}
.aircraft-sheet-photo {
  width: 132px;
  height: 82px;
  object-fit: cover;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--panel-2);
}
.aircraft-sheet-summary {
  display: grid;
  gap: 5px;
  flex: 1 1 auto;
  min-width: 0;
}
.aircraft-operator {
  overflow: hidden;
  color: var(--text);
  font-size: 0.86rem;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sheet-route-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 42px minmax(0, 1fr);
  align-items: center;
  gap: 6px;
  min-height: 42px;
  text-align: center;
}
.sheet-route-grid div:not(.sheet-phase-icon) {
  display: grid;
  gap: 2px;
  min-width: 0;
  padding: 5px 7px;
  border-radius: 10px;
  background: var(--panel-2);
}
.sheet-route-grid strong {
  overflow: hidden;
  font-size: 1rem;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sheet-route-grid span {
  color: var(--muted);
  font-size: 0.58rem;
  font-weight: 850;
  text-transform: uppercase;
}
.sheet-phase-icon {
  display: grid;
  place-items: center;
}
.phase-plane {
  display: grid;
  place-items: center;
  width: 34px;
  height: 34px;
  color: #facc15;
  transform: rotate(var(--phase-angle));
  filter: drop-shadow(0 3px 6px rgba(15,23,42,.34));
}
.phase-plane svg { width: 31px; height: 31px; fill: currentColor; }
.phase-climb { color: #22c55e; }
.phase-descent { color: #f97316; }
.phase-ground { color: #64748b; }
.phase-level { color: #facc15; }
.sheet-route-caption {
  overflow: hidden;
  color: var(--muted);
  font-size: 0.68rem;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.aircraft-sheet-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
}
.aircraft-sheet-cards div {
  display: grid;
  gap: 2px;
  min-width: 0;
  padding: 7px 8px;
  border-radius: 10px;
  background: var(--panel-2);
}
.aircraft-sheet-cards span {
  overflow: hidden;
  color: var(--muted);
  font-size: 0.61rem;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-transform: uppercase;
}
.aircraft-sheet-cards strong {
  overflow: hidden;
  font-size: 0.82rem;
  line-height: 1.05;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.aircraft-sheet-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 6px;
}
.aircraft-sheet-actions button {
  min-height: 40px;
  border: 0;
  border-radius: 11px;
  color: var(--text);
  background: var(--button);
  font-size: 0.74rem;
  font-weight: 900;
}
.aircraft-sheet-actions #aircraftSheetSave { color: #052e16; background: var(--accent); }
.aircraft-sheet-more {
  display: grid;
  gap: 4px;
  max-height: 210px;
  overflow: auto;
  padding-top: 4px;
}
.detail-row {
  display: grid;
  grid-template-columns: 140px minmax(0, 1fr);
  gap: 8px;
  padding: 5px 7px;
  border-radius: 8px;
  background: var(--panel-3);
}
.detail-name {
  color: var(--muted);
  font-size: 0.68rem;
  font-weight: 850;
}
.detail-value {
  overflow-wrap: anywhere;
  font-size: 0.74rem;
}
.map-popup {
  gap: 6px;
  min-width: 190px;
  max-width: 230px;
  font-size: 0.8rem;
}
.map-popup-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}
.map-popup-title-block { display: grid; min-width: 0; }
.map-popup-title { color: #f59e0b; font-size: 0.94rem; }
.map-popup-type { color: var(--muted); font-size: 0.68rem; font-weight: 850; }
.map-popup-phase {
  display: grid;
  place-items: center;
  gap: 1px;
  min-width: 45px;
}
.map-popup-phase .phase-plane { width: 28px; height: 28px; }
.map-popup-phase .phase-plane svg { width: 25px; height: 25px; }
.map-popup-phase-text { color: var(--muted); font-size: 0.56rem; font-weight: 900; text-align: center; }
.map-popup-photo {
  width: 100%;
  height: 94px;
  border-radius: 10px;
}
.map-popup-route-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 30px minmax(0, 1fr);
  align-items: center;
  gap: 4px;
  text-align: center;
}
.route-code {
  overflow: hidden;
  padding: 5px 6px;
  border-radius: 9px;
  background: var(--panel-2);
  font-size: 0.9rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.route-plane { color: #facc15; font-size: 1.05rem; }
.map-popup-metrics {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4px;
}
.metric-card {
  display: grid;
  gap: 1px;
  min-width: 0;
  padding: 5px;
  border-radius: 8px;
  background: var(--panel-2);
}
.metric-label { color: var(--muted); font-size: 0.56rem; font-weight: 900; text-transform: uppercase; }
.metric-value { overflow: hidden; font-size: 0.66rem; text-overflow: ellipsis; white-space: nowrap; }
.map-popup-meta { font-size: 0.68rem; }
.popup-save-button { min-height: 32px; }

@media (max-width: 760px) {
  .flight-item {
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 5px;
    min-height: 38px;
    padding: 5px 6px;
  }
  .flight-actions .icon-button,
  .flight-item .icon-button {
    flex: 0 0 auto;
    min-width: 30px;
    min-height: 25px;
    padding: 0 4px;
    font-size: 0.58rem;
  }
  .flight-card-main { grid-template-columns: 24px minmax(0, 1fr); }
  .flight-thumb { width: 24px; height: 24px; }
  .flight-name { font-size: 0.74rem; }
  .flight-meta { font-size: 0.6rem; }
  .aircraft-sheet {
    bottom: calc(78px + var(--safe-bottom));
    width: 100vw;
    max-height: 50dvh;
    border-right: 0;
    border-bottom: 0;
    border-left: 0;
    border-radius: 18px 18px 0 0;
  }
  .aircraft-sheet-photo-wrap { flex-basis: 104px; }
  .aircraft-sheet-photo { width: 104px; height: 66px; }
  .aircraft-sheet-cards { grid-template-columns: repeat(2, 1fr); }
  .aircraft-sheet-actions { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 4px; }
  .aircraft-sheet-actions button { min-height: 36px; font-size: 0.64rem; padding: 0 3px; }
  .detail-row { grid-template-columns: 104px minmax(0, 1fr); }
  .map-status-card { display: none; }
}


/* v2.2 poprawki paneli */
.control-column.is-expanded {
  max-height: min(88dvh, 900px);
}
.aircraft-sheet.is-expanded {
  max-height: min(78dvh, 760px);
}
@media (max-width: 760px) {
  .drawer-drag-handle,
  .aircraft-sheet-drag-handle { display: block; }
  .drawer-header { padding-top: 10px; }
  .control-column.is-expanded { max-height: calc(100dvh - 92px - var(--safe-bottom)); }
  .aircraft-sheet.is-expanded { max-height: calc(100dvh - 84px - var(--safe-bottom)); }
  .aircraft-sheet-actions { grid-template-columns: repeat(3, minmax(0, 1fr)) !important; }
}

/* v2.4: stabilniejsza obsługa ADS, cache i układ listy samolotów */
.drawer-drag-handle,
.aircraft-sheet-drag-handle {
  touch-action: none;
  cursor: grab;
}
.drawer-drag-handle:active,
.aircraft-sheet-drag-handle:active { cursor: grabbing; }

.control-column.is-open {
  transform: translate(-50%, var(--sheet-drag-y, 0px)) scale(1);
}
.control-column.is-dragging,
.aircraft-sheet.is-dragging {
  transition: none !important;
}

.aircraft-sheet {
  pointer-events: none;
}
.aircraft-sheet.is-open {
  pointer-events: auto;
  transform: translate(-50%, var(--sheet-drag-y, 0px));
}

.aircraft-div-icon {
  pointer-events: none;
}
.plane-marker-wrap {
  pointer-events: none;
}
.plane-marker {
  pointer-events: auto;
}
.plane-label {
  pointer-events: none;
}

.flight-item .open-flight {
  min-width: 74px;
}

@media (max-width: 760px) {
  .control-column {
    bottom: calc(84px + var(--safe-bottom));
    max-height: 60dvh;
  }
  .control-column.is-expanded {
    max-height: calc(100dvh - 88px - var(--safe-bottom));
  }
  .flight-item {
    grid-template-columns: minmax(0, 1fr) auto;
  }
  .flight-item .flight-actions {
    display: flex;
    flex-wrap: nowrap;
    gap: 3px;
    max-width: 52vw;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .flight-item .flight-actions::-webkit-scrollbar { display: none; }
  .flight-item .icon-button {
    flex: 0 0 auto;
    min-width: 42px;
    min-height: 30px;
  }
  .flight-item .open-flight {
    min-width: 72px;
  }
}

/* Poprawki 2.6: przywrócony ADS w zapisanych, bez Kopiuj i Śledź */
.search-field-label { display: grid; gap: 6px; }
.search-field-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 44px;
  gap: 6px;
  align-items: center;
}
.search-field-row input { min-width: 0; }
.search-icon-button {
  width: 44px;
  min-height: 42px;
  border: 0;
  border-radius: 12px;
  color: var(--text);
  background: var(--accent);
  font-size: 1.05rem;
  font-weight: 900;
  cursor: pointer;
}
.search-icon-button:active { transform: translateY(1px); }
.flight-actions-compact {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(42px, auto)) !important;
  gap: 4px !important;
  justify-content: end;
  max-width: none !important;
  overflow: visible !important;
}
.flight-actions-compact .icon-button {
  min-width: 48px;
  min-height: 32px;
}

@media (max-width: 760px) {
  .search-field-row { grid-template-columns: minmax(0, 1fr) 42px; }
  .search-icon-button { width: 42px; min-height: 40px; }
  .flight-actions-compact {
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    width: 100% !important;
  }
  .flight-actions-compact .icon-button {
    width: 100%;
    min-width: 0;
  }
}


/* V4 — alerty i obserwowane */
.alert-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr 0.8fr;
  gap: 10px;
  margin: 10px 0;
}
.alert-enable-row { margin-bottom: 10px; }
.alert-actions { margin-top: 10px; }
.alert-log-list {
  display: grid;
  gap: 8px;
  max-height: 28dvh;
  overflow: auto;
  margin: 8px 0 0;
  padding: 0;
  list-style: none;
}
.alert-log-item {
  display: grid;
  grid-template-columns: 72px 1fr;
  gap: 8px;
  padding: 8px 10px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: var(--panel-2);
  color: var(--muted);
  font-size: 0.82rem;
}
.alert-log-item strong { color: var(--text); }
.alert-log-item.muted { grid-template-columns: 1fr; }
.watch-item.is-live {
  border-color: rgba(34, 197, 94, 0.5);
  background: rgba(34, 197, 94, 0.08);
}
.watch-list { max-height: 42dvh; }

@media (max-width: 760px) {
  .bottom-nav {
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 3px;
  }
  .bottom-nav button {
    min-height: 54px;
    font-size: 0.68rem;
    border-radius: 14px;
  }
  .bottom-more-menu {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 7px;
    padding: 8px;
  }
  .bottom-more-menu button {
    min-height: 44px;
    font-size: 0.82rem;
  }
  .nav-icon { font-size: 1.08rem; }
  .alert-grid { grid-template-columns: 1fr; }
  .alert-log-item { grid-template-columns: 58px 1fr; font-size: 0.76rem; }
}

/* V6 - 2905262145: rozszerzony panel szczegółów i świeżość danych */
.freshness-badge {
  display: inline-grid;
  place-items: center;
  min-width: 72px;
  max-width: 156px;
  min-height: 26px;
  padding: 3px 8px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: var(--panel-2);
  color: var(--muted);
  font-size: 0.66rem;
  font-weight: 950;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}
.freshness-live,
.freshness-fresh {
  border-color: rgba(34, 197, 94, 0.42);
  background: rgba(34, 197, 94, 0.14);
  color: #166534;
}
.freshness-delayed {
  border-color: rgba(245, 158, 11, 0.46);
  background: rgba(245, 158, 11, 0.15);
  color: #92400e;
}
.freshness-stale {
  border-color: rgba(220, 38, 38, 0.42);
  background: rgba(220, 38, 38, 0.12);
  color: #991b1b;
}
.freshness-unknown {
  border-color: var(--line);
  background: var(--panel-2);
  color: var(--muted);
}
[data-theme="dark"] .freshness-live,
[data-theme="dark"] .freshness-fresh { color: #86efac; }
[data-theme="dark"] .freshness-delayed { color: #fbbf24; }
[data-theme="dark"] .freshness-stale { color: #fca5a5; }
.aircraft-sheet-head {
  align-items: start;
}
.aircraft-sheet-head #aircraftSheetFreshness {
  flex: 0 0 auto;
  margin-left: auto;
}
.aircraft-sheet-live-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 6px;
}
.aircraft-sheet-live-grid div {
  display: grid;
  gap: 2px;
  min-width: 0;
  padding: 7px 8px;
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 10px;
  background: var(--panel-3);
}
.aircraft-sheet-live-grid span {
  overflow: hidden;
  color: var(--muted);
  font-size: 0.58rem;
  font-weight: 950;
  text-overflow: ellipsis;
  text-transform: uppercase;
  white-space: nowrap;
}
.aircraft-sheet-live-grid strong {
  overflow: hidden;
  font-size: 0.73rem;
  line-height: 1.08;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.aircraft-list-freshness {
  width: fit-content;
  min-width: 54px;
  min-height: 20px;
  padding: 2px 6px;
  font-size: 0.58rem;
}
.plane-freshness {
  position: absolute;
  left: 50%;
  top: -12px;
  transform: translateX(-50%);
  padding: 1px 5px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.94);
  color: #111827;
  font-size: 9px;
  font-weight: 950;
  line-height: 1.25;
  box-shadow: 0 2px 6px rgba(15, 23, 42, 0.16);
  pointer-events: none;
  white-space: nowrap;
}
[data-theme="dark"] .plane-freshness {
  background: rgba(15, 23, 42, 0.94);
  color: #f8fafc;
}
.aircraft-freshness-stale .plane-marker { opacity: 0.62; }
.aircraft-freshness-delayed .plane-marker { opacity: 0.82; }
.aircraft-freshness-unknown .plane-marker { opacity: 0.72; }
@media (max-width: 760px) {
  .aircraft-sheet-live-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .aircraft-sheet-head { gap: 6px; }
  .aircraft-sheet-head #aircraftSheetFreshness { max-width: 126px; font-size: 0.58rem; }
  .plane-freshness { display: none; }
}
.plane-marker-wrap { position: relative; }


/* V6 - 2905262145: automatyczne usuwanie starych samolotów i tryb wydajności */
.performance-details {
  border: 1px solid var(--line);
  border-radius: 16px;
  background: var(--panel-2);
  padding: 10px;
}
.performance-details summary {
  cursor: pointer;
  font-weight: 950;
}
.performance-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  margin-top: 10px;
}
.performance-grid label {
  min-width: 0;
}
.aircraft-lifecycle-stale .plane-marker,
.aircraft-lifecycle-expired .plane-marker {
  opacity: 0.42;
  filter: grayscale(0.45);
}
.aircraft-lifecycle-stale .plane-label,
.aircraft-lifecycle-expired .plane-label {
  opacity: 0.68;
}
.aircraft-item[data-lifecycle="stale"] {
  opacity: 0.7;
}
.aircraft-item[data-lifecycle="expired"] {
  display: none;
}
@media (max-width: 760px) {
  .performance-grid { grid-template-columns: 1fr; }
}


/* V7 - historia przelotów */
.history-list { max-height: 42dvh; }
.history-item {
  border-color: rgba(37, 99, 235, 0.18);
}
.history-item .flight-meta {
  white-space: normal;
  line-height: 1.18;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.history-badge {
  display: inline-flex;
  align-items: center;
  min-height: 20px;
  padding: 2px 7px;
  border-radius: 999px;
  border: 1px solid rgba(37, 99, 235, 0.25);
  background: rgba(37, 99, 235, 0.08);
  color: var(--text);
  font-size: 0.68rem;
  font-weight: 700;
}
@media (max-width: 760px) {
  .history-list { max-height: 38dvh; }
  .history-item .flight-actions {
    flex-wrap: wrap;
    justify-content: flex-end;
  }
}


.sync-settings-card {
  display: grid;
  gap: 10px;
  padding: 12px;
  margin-top: 12px;
  border: 1px solid rgba(15, 23, 42, .12);
  border-radius: 16px;
  background: rgba(255, 255, 255, .72);
}
.sync-settings-card strong {
  display: block;
  margin-bottom: 4px;
}
.sync-status {
  margin: 0;
  font-size: .88rem;
  color: #475569;
}
.sync-status[data-mode="ok"] { color: #047857; }
.sync-status[data-mode="busy"] { color: #0369a1; }
.sync-status[data-mode="error"] { color: #b91c1c; }
.sync-settings-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.setup-modal {
  position: fixed;
  inset: 0;
  z-index: 11000;
  display: grid;
  place-items: center;
  padding: 18px;
  background: rgba(15, 23, 42, .42);
  backdrop-filter: blur(8px);
}
.setup-modal[hidden] { display: none; }
.setup-card {
  width: min(780px, 100%);
  max-height: min(92vh, 820px);
  overflow: auto;
  display: grid;
  gap: 12px;
  padding: 18px;
  border-radius: 22px;
  border: 1px solid rgba(15, 23, 42, .14);
  background: #f8fafc;
  box-shadow: 0 30px 90px rgba(15, 23, 42, .28);
}
.setup-head {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
}
.setup-head h2,
.setup-head p { margin: 0; }
.setup-head h2 { margin-bottom: 6px; }
.setup-card textarea,
.setup-card input { width: 100%; }
.setup-card textarea {
  min-height: 110px;
  font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
  resize: vertical;
}
.setup-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}
.field-hint {
  display: block;
  margin-top: 4px;
  font-size: .78rem;
  color: #64748b;
}
.setup-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: flex-end;
}
body.modal-open { overflow: hidden; }

@media (max-width: 760px) {
  .map-floating-controls {
    right: calc(10px + env(safe-area-inset-right, 0px));
    bottom: calc(150px + var(--safe-bottom));
  }
  .map-location-button {
    width: 44px;
    height: 44px;
    border-radius: 15px;
    font-size: 1.25rem;
  }
}

@media (max-width: 640px) {
  .setup-modal {
    align-items: end;
    padding: 10px;
  }
  .setup-card {
    max-height: 92vh;
    border-radius: 20px 20px 16px 16px;
    padding: 14px;
  }
  .setup-grid { grid-template-columns: 1fr; }
  .setup-actions,
  .sync-settings-actions {
    display: grid;
    grid-template-columns: 1fr;
  }
}
